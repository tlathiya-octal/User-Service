<?xml version="1.0" encoding="UTF-8"?>
<!--
  logback-spring.xml — User Service
  ════════════════════════════════════════════════════════════════════════════
  Every log line carries:
    • ISO-8601 timestamp with milliseconds
    • Colour-coded level (console only)
    • Thread
    • correlationId from MDC  ← propagated by CorrelationIdFilter
    • Abbreviated logger name
    • Message + exception

  Appenders:
    CONSOLE   — coloured, always active
    ASYNC_FILE — plain text, active outside local/default profiles
                 Rolls daily or at 50 MB; 30-day / 1 GB cap
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ── Spring property binding ─────────────────────────────────────────── -->
    <springProperty scope="context" name="APP_NAME"
                    source="spring.application.name" defaultValue="user-service"/>

    <!-- ── Properties ─────────────────────────────────────────────────────── -->
    <property name="LOG_DIR"        value="logs"/>
    <property name="MAX_HISTORY"    value="30"/>
    <property name="MAX_FILE_SIZE"  value="50MB"/>
    <property name="TOTAL_SIZE_CAP" value="1GB"/>

    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan([CID:%X{correlationId:-n/a}]) [%yellow(${APP_NAME})] %logger{36} - %msg%n%ex"/>

    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [CID:%X{correlationId:-n/a}] [${APP_NAME}] %logger{36} - %msg%n%ex"/>

    <!-- ── Console Appender ────────────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Rolling File Appender ──────────────────────────────────────────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Async wrapper for FILE (prevents I/O blocking the request thread) -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="FILE"/>
    </appender>

    <!-- ── Logger tuning ──────────────────────────────────────────────────── -->
    <!-- Suppress verbose Spring Security debug output -->
    <logger name="org.springframework.security"        level="WARN"/>
    <!-- Suppress Hibernate SQL param binding logs -->
    <logger name="org.hibernate.type.descriptor.sql"  level="WARN"/>
    <logger name="org.hibernate.orm.jdbc.bind"         level="WARN"/>
    <!-- Suppress Eureka heartbeat noise -->
    <logger name="com.netflix"                         level="WARN"/>
    <logger name="io.micrometer"                       level="WARN"/>
    <!-- Suppress Redis cache debug -->
    <logger name="org.springframework.data.redis"      level="INFO"/>
    <!-- Suppress MapStruct debug output -->
    <logger name="org.mapstruct"                       level="WARN"/>

    <!-- Application — DEBUG so filter log lines are always visible -->
    <logger name="com.ecommerce.user"                  level="DEBUG"/>

    <!-- ── Root / profile-specific active appenders ───────────────────────── -->
    <springProfile name="local,default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!local &amp; !default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>
    </springProfile>

</configuration>
